{
  "info": {
    "name": "RenderShot — Screenshot & PDF API (via RapidAPI)",
    "description": "Capture website screenshots (PNG/JPEG/WebP) and generate PDFs from URL or HTML. RenderShot is served through RapidAPI: set the `apiKey` variable to your RapidAPI key, then send any request.\n\nGet a key: https://rapidapi.com/eduardoalcantarasp/api/screenshot-e-pdf-render\nDocs: https://api.rendershot.dev/docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "rapidApiHost", "value": "screenshot-e-pdf-render.p.rapidapi.com", "type": "string" },
    { "key": "apiKey", "value": "YOUR_RAPIDAPI_KEY", "type": "string" }
  ],
  "item": [
    {
      "name": "Health (public)",
      "request": {
        "method": "GET",
        "url": { "raw": "https://api.rendershot.dev/health", "protocol": "https", "host": ["api", "rendershot", "dev"], "path": ["health"] }
      }
    },
    {
      "name": "Screenshot (GET)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-RapidAPI-Key", "value": "{{apiKey}}" },
          { "key": "X-RapidAPI-Host", "value": "{{rapidApiHost}}" }
        ],
        "url": {
          "raw": "https://{{rapidApiHost}}/v1/screenshot?url=https://example.com&fullPage=true&type=png",
          "protocol": "https",
          "host": ["{{rapidApiHost}}"],
          "path": ["v1", "screenshot"],
          "query": [
            { "key": "url", "value": "https://example.com" },
            { "key": "fullPage", "value": "true" },
            { "key": "type", "value": "png", "description": "png | jpeg | webp" },
            { "key": "device", "value": "iphone_15", "disabled": true },
            { "key": "darkMode", "value": "true", "disabled": true },
            { "key": "blockCookieBanners", "value": "true", "disabled": true },
            { "key": "waitForSelector", "value": ".loaded", "disabled": true }
          ]
        }
      }
    },
    {
      "name": "Screenshot (POST)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-RapidAPI-Key", "value": "{{apiKey}}" },
          { "key": "X-RapidAPI-Host", "value": "{{rapidApiHost}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"url\": \"https://stripe.com\",\n  \"type\": \"webp\",\n  \"fullPage\": true,\n  \"blockCookieBanners\": true\n}" },
        "url": { "raw": "https://{{rapidApiHost}}/v1/screenshot", "protocol": "https", "host": ["{{rapidApiHost}}"], "path": ["v1", "screenshot"] }
      }
    },
    {
      "name": "Generate PDF (POST)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-RapidAPI-Key", "value": "{{apiKey}}" },
          { "key": "X-RapidAPI-Host", "value": "{{rapidApiHost}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"html\": \"<h1>Invoice #42</h1><p>Total: $99.00</p>\",\n  \"format\": \"A4\",\n  \"pageNumbers\": true\n}" },
        "url": { "raw": "https://{{rapidApiHost}}/v1/pdf", "protocol": "https", "host": ["{{rapidApiHost}}"], "path": ["v1", "pdf"] }
      }
    },
    {
      "name": "Usage stats (GET)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-RapidAPI-Key", "value": "{{apiKey}}" },
          { "key": "X-RapidAPI-Host", "value": "{{rapidApiHost}}" }
        ],
        "url": { "raw": "https://{{rapidApiHost}}/v1/usage", "protocol": "https", "host": ["{{rapidApiHost}}"], "path": ["v1", "usage"] }
      }
    }
  ]
}
