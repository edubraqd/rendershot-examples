{
  "info": {
    "name": "RenderShot — Screenshot & PDF API",
    "description": "Capture website screenshots (PNG/JPEG/WebP) and generate PDFs from URL or HTML. Set the `apiKey` collection variable, then send any request.\n\nGet a key: https://rapidapi.com/eduardoalcantarasp/api/screenshot-e-pdf-render\nDocs: https://api.rendershot.dev/docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.rendershot.dev", "type": "string" },
    { "key": "apiKey", "value": "YOUR_KEY", "type": "string" }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "x-api-key", "type": "string" },
      { "key": "value", "value": "{{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "auth": { "type": "noauth" },
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Screenshot (GET)",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-api-key", "value": "{{apiKey}}" }],
        "url": {
          "raw": "{{baseUrl}}/v1/screenshot?url=https://example.com&fullPage=true&type=png",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "screenshot"],
          "query": [
            { "key": "url", "value": "https://example.com" },
            { "key": "fullPage", "value": "true" },
            { "key": "type", "value": "png", "description": "png | jpeg | webp" },
            { "key": "device", "value": "iphone_15", "disabled": true },
            { "key": "darkMode", "value": "true", "disabled": true },
            { "key": "blockAds", "value": "true", "disabled": true },
            { "key": "blockCookieBanners", "value": "true", "disabled": true },
            { "key": "waitForSelector", "value": ".loaded", "disabled": true },
            { "key": "response", "value": "json", "disabled": true }
          ]
        }
      }
    },
    {
      "name": "Screenshot (POST)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-api-key", "value": "{{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"https://stripe.com\",\n  \"type\": \"webp\",\n  \"fullPage\": true,\n  \"blockCookieBanners\": true\n}"
        },
        "url": { "raw": "{{baseUrl}}/v1/screenshot", "host": ["{{baseUrl}}"], "path": ["v1", "screenshot"] }
      }
    },
    {
      "name": "Generate PDF (POST)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-api-key", "value": "{{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"html\": \"<h1>Invoice #42</h1><p>Total: $99.00</p>\",\n  \"format\": \"A4\",\n  \"pageNumbers\": true\n}"
        },
        "url": { "raw": "{{baseUrl}}/v1/pdf", "host": ["{{baseUrl}}"], "path": ["v1", "pdf"] }
      }
    },
    {
      "name": "Usage stats (GET)",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-api-key", "value": "{{apiKey}}" }],
        "url": { "raw": "{{baseUrl}}/v1/usage", "host": ["{{baseUrl}}"], "path": ["v1", "usage"] }
      }
    }
  ]
}
